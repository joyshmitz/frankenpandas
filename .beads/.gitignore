# Database
*.db
*.db-journal
*.db-shm
*.db-wal

# Lock files
*.lock

# Temporary
last-touched
*.tmp

# Local history backups
.br_history/
.br_recovery/

# Sync state (local-only, per-machine)
.sync.lock
sync_base.jsonl

# Merge artifacts (temporary files from 3-way merge)
beads.base.jsonl
beads.base.meta.json
beads.left.jsonl
beads.left.meta.json
beads.right.jsonl
beads.right.meta.json

# Daemon runtime files
daemon.lock
daemon.log
daemon.pid
bd.sock
sync-state.json

# Worktree redirect file
redirect

# bv (beads viewer) lock file
.bv.lock

# Per-host beads DB snapshots from agent recovery flows
# (e.g. beads.db.bak-cc1-20260503T041757Z, beads.db-shm.bak-tlcr3,
# issues.jsonl.bak-tlcr3). The earlier *.db / *.db-shm / *.db-wal
# patterns above only match those exact suffixes, so the .bak-*
# variants slip through and recur untracked across rounds.
*.bak-*
